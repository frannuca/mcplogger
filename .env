# .env - Local environment variables (DO NOT commit to git)
# Copy .env.example to .env and fill in your values

# ── LLM backend ───────────────────────────────────────────────────────────────
# Option A: OpenAI cloud (default)
#OPENAI_API_KEY=here your key
#OPENAI_MODEL=gpt-4o-mini

# Option B: llama.cpp local
# 1. Start server:  llama-server -m /path/to/your-model.gguf --port 8080
# 2. Uncomment these three lines:
LLM_BASE_URL=http://localhost:8080/v1
LLM_API_KEY=local
OPENAI_MODEL=local   # llama.cpp ignores the model name, loaded model is used

# ── Embedding (semantic / vector search) ─────────────────────────────────────
# Optional: set LLM_EMBEDDING_URL to enable vector search instead of regex.
# Requires a SEPARATE llama.cpp server loaded with an embedding model:
#   llama-server -m nomic-embed-text-v1.5.Q4_K_M.gguf --port 8081 --embeddings
# Then uncomment:
LLM_EMBEDDING_URL=http://localhost:8081/v1
LLM_EMBEDDING_MODEL=nomic-embed-text   # ignored by llama.cpp, document for humans

# ── Log files ─────────────────────────────────────────────────────────────────
LOG_FILES="/Users/fran/mcps/mcplogger/test_app.log"

BUCKET_MINUTES=5
HIGH_ERROR_THRESHOLD=0.20
MAX_SUMMARY_ITEMS=30

