# ── LLM backend ───────────────────────────────────────────────────────────────
# Option A: OpenAI cloud (default — LLM_BASE_URL not required)
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Option B: llama.cpp local server
# 1. Start server:  llama-server -m /path/to/model.gguf --port 8080
# 2. Replace Option A with:
#LLM_BASE_URL=http://localhost:8080/v1
#LLM_API_KEY=local
#OPENAI_MODEL=local

# Option C: Ollama
#LLM_BASE_URL=http://localhost:11434/v1
#LLM_API_KEY=local
#OPENAI_MODEL=llama3

# ── Embedding / semantic search (optional) ────────────────────────────────────
# Set LLM_EMBEDDING_URL to enable vector similarity search instead of regex.
# Requires a second llama.cpp server loaded with an embedding model:
#   llama-server -m nomic-embed-text-v1.5.Q4_K_M.gguf --port 8081 --embeddings
#LLM_EMBEDDING_URL=http://localhost:8081/v1
#LLM_EMBEDDING_MODEL=nomic-embed-text

# ── Log files ─────────────────────────────────────────────────────────────────
LOG_FILES=/path/to/app.log,/path/to/worker.log

# Analysis configuration
BUCKET_MINUTES=5
HIGH_ERROR_THRESHOLD=0.20
MAX_SUMMARY_ITEMS=30
